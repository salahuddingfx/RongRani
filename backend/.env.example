# ========================================
# REQUIRED - Core Settings (Must Configure)
# ========================================

# MongoDB Connection (REQUIRED)
MONGO_URI=mongo uri

# JWT Configuration (REQUIRED)
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=30d

# Server Configuration (REQUIRED)
PORT=5000
FRONTEND_URL=http://localhost:5178

# ========================================
# OPTIONAL - Email Service (Brevo/SendinBlue)
# If not set, emails will be logged to console only
# ========================================
# BREVO_API_KEY=your_brevo_api_key_here
# BREVO_SMTP_HOST=smtp-relay.brevo.com
# BREVO_SMTP_PORT=587
# BREVO_SMTP_USER=your_smtp_user_here
# BREVO_SMTP_PASS=your_smtp_password_here
# FROM_EMAIL=your_email@example.com
# FROM_NAME=Your App Name

# ========================================
# OPTIONAL - Cloudinary (Image Storage)
# If not set, placeholder images will be used
# ========================================
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_cloudinary_api_key
# CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ========================================
# OPTIONAL - AI Service (Google Gemini)
# If not set, fallback responses will be used
# ========================================
# GEMINI_API_KEY=your_gemini_api_key_here

# ========================================
# OPTIONAL - Super Admin Credentials
# Default admin will be created if not set
# ========================================
# SUPER_ADMIN_EMAIL=admin@example.com
# SUPER_ADMIN_PASSWORD=your_secure_admin_password

# ========================================
# OPTIONAL - OAuth Social Login
# If not set, only email/password login available
# ========================================
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# FACEBOOK_APP_ID=your_facebook_app_id
# FACEBOOK_APP_SECRET=your_facebook_app_secret

# ========================================
# OPTIONAL - Steadfast Courier API (Bangladesh Delivery)
# If not set, manual delivery tracking only
# ========================================
# STEADFAST_API_KEY=your_steadfast_api_key
# STEADFAST_API_SECRET=your_steadfast_api_secret
# STEADFAST_BASE_URL=https://portal.steadfast.com.bd/api/v1
